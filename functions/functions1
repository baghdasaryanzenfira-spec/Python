text="   Hello world "
text1="Hello World "

#1 
def my_split(mstr):
    """Split() funkciayi irakanacum: """
    lst=[]
    temp=""
    for i in mstr:
        if i==" ":
            lst.append(temp)
            temp=""
        else:
            temp+=i
    lst.append(temp)
    return lst
print(my_split(text))

#2 
def my_strip(mstr):
    """Strip() funkciayi irakanacum: """
    start=0
    end=len(mstr)-1
    while start<=end and mstr[start]==" ":
        start+=1
    while end>=start and mstr[end]==" ":
        end-=1
    return ''.join(mstr[i] for i in range(start,end+1))
print(my_strip(text))

#3
def my_replace(s,old,new):
    """replace() funkciayi irakanacum: """
    result=""
    i=0
    while i<len(s):
        if s[i:i+len(old)]==old:
            result+=new
            i+=len(old)
        else:
            result+=s[i]
            i+=1
    return result
print(my_replace(text,"world","Python"))

