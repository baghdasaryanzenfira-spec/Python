def capitalize(mstr):
    """capitalize() funkciayi irakanacum: """
    if not mstr:
        return ""
    first=mstr[0]
    if 'a'<= first <='z':
        first=chr(ord(first)-32)
    ml=""
    for i in mstr[1:]:
        if 'A'<= i<='Z':
            ml+=chr(ord(i)+32)
        else:
            ml+=i
    return first+ml
print(capitalize(text1))

#5
def my_title(mstr):
    """title() funkciayi irakanacum: """
    ml=""
    nl=""
    for i in mstr:
        if 'a'<= i <='z' and (nl==' '):
            ml+=chr(ord(i)-32)
        elif 'A'<= i <= 'Z'and (nl!=' '):
            ml+=chr(ord(i)+32)
        else:
            ml+=i
        nl=i
    return ml
print(my_title(text))

